{
  "name": "basta-frontend",
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/testSetup.js"
    ],
    "moduleNameMapper": {
      "\\.(css|jpg|png)$": "<rootDir>/empty-module.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|lodash-es|react-redux)/)"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx"
    ],
    "moduleDirectories": [
      "node_modules"
    ]
  },
  "version": "74.0.0",
  "description": "frontend til basta",
  "engines": {
    "node": ">=24"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Safari versions"
  ],
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@fortawesome/free-solid-svg-icons": "^5.15.4",
    "@redux-devtools/extension": "^3.3.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "history": "^5.3.0",
    "http-proxy-middleware": "^3.0.5",
    "moment": "^2.29.4",
    "morgan": "^1.10.1",
    "pretty-quick": "^4.2.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-regenerator": "^7.20.5",
    "@babel/plugin-transform-runtime": "^7.21.0",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@fortawesome/fontawesome-free": "^5.15.4",
    "@parcel/transformer-less": "^2.16.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^30.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "font-awesome": "^4.7.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "less": "^4.6.4",
    "lodash.throttle": "^4.1.1",
    "ncp": "^2.0.0",
    "nodemon": "^3.1.14",
    "parcel": "^2.16.4",
    "prettier": "^3.8.2",
    "prop-types": "^15.7.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.2",
    "react-select": "^5.10.2",
    "react-tooltip": "^6.0.0",
    "redux": "^5.0.1",
    "redux-mock-store": "^1.5.4",
    "redux-saga": "^1.4.2",
    "redux-saga-test-plan": "^4.0.6",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "test": "jest",
    "start": "cross-env NODE_ENV=production node api/src/server.js",
    "build": "cross-env NODE_ENV=production rimraf dist/ && parcel build frontend/index.html --public-url /static",
    "prebuild": "npm run mkdir && npm run copy-fonts",
    "prefrontend": "npm run prebuild",
    "mkdir": "node -e \"require('node:fs').mkdirSync('frontend/fonts',{recursive:true})\"",
    "copy-fonts": "ncp node_modules/font-awesome/fonts/ frontend/fonts",
    "frontend": "cross-env NODE_ENV=development parcel frontend/index.html --public-url /static",
    "api": "cross-env NODE_ENV=development BASTA_BACKEND=http://localhost:6996 concurrently -k -n parcel,api -c blue,green \"parcel frontend/index.html --public-url /static\" \"nodemon api/src/server.js\"",
    "real-basta-backend": "cross-env NODE_ENV=development BASTA_BACKEND=http://localhost:1337 nodemon api/src/server.js",
    "offline": "cross-env NODE_ENV=offline BASTA_BACKEND=http://localhost:6996 concurrently -k -n parcel,api -c blue,green \"parcel frontend/index.html --public-url /static\" \"nodemon api/test/server.js\"",
    "mockend": "cross-env NODE_ENV=offline nodemon api/test/mockend/mock-backend.js",
    "prepare": "husky || true"
  },
  "nodemonConfig": {
    "ignore": [
      "dist/*"
    ]
  },
  "keywords": [
    "frontend",
    "react",
    "parcel",
    "redux",
    "saga",
    "basta",
    "react-router"
  ],
  "author": "@navikt/aura",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "lmdb",
      "msgpackr-extract"
    ],
    "overrides": {
      "semver@<5.7.2": "^5.7.2",
      "brace-expansion@>=1.0.0 <1.1.12": "^1.1.12",
      "yaml@>=1.0.0 <1.10.3": "^1.10.3"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
